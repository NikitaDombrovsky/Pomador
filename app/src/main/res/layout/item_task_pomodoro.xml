<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="?attr/appSurfaceColor"
    app:cardCornerRadius="6dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="?attr/appDividerColor" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="center_vertical">

            <!-- Drag handle -->
            <TextView
                android:id="@+id/drag_handle"
                android:layout_width="24dp"
                android:layout_height="wrap_content"
                android:text="☰"
                android:textColor="?attr/appSubtextColor"
                android:textSize="18sp"
                android:layout_marginEnd="8dp" />

            <!-- Текст задачи -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/task_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="?attr/appTextColor"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/task_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="?attr/appSubtextColor"
                    android:textSize="13sp" />

            </LinearLayout>

            <!-- Помидорки: − счётчик + -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginStart="8dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_tomato_minus"
                    style="@style/MetalButton"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:text="−"
                    android:textSize="16sp"
                    android:padding="0dp"
                    app:strokeWidth="1dp" />

                <TextView
                    android:id="@+id/tv_tomatoes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="4dp"
                    android:textSize="16sp"
                    android:textColor="?attr/appTextColor"
                    android:minWidth="40dp"
                    android:gravity="center" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_tomato_plus"
                    style="@style/MetalButton"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:text="+"
                    android:textSize="16sp"
                    android:padding="0dp"
                    app:strokeWidth="1dp" />

            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/task_edit_button"
                style="@style/MetalButton"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="6dp"
                android:text="✎"
                android:textSize="13sp"
                android:padding="0dp"
                app:strokeWidth="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/task_remove_button"
                style="@style/MetalButton"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="4dp"
                android:text="✕"
                android:textSize="13sp"
                android:padding="0dp"
                app:strokeColor="?attr/appRedColor"
                app:strokeWidth="1dp" />

        </LinearLayout>
    </LinearLayout>

</androidx.cardview.widget.CardView>
